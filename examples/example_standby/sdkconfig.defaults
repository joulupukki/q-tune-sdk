# sdkconfig.defaults — example_standby plugin
#
# Mirrors the firmware's LVGL configuration so that struct layouts match.
# See example_tuner/sdkconfig.defaults for full commentary.

# --- Color depth: 16-bit RGB565 — MANDATORY, must match firmware ----------
CONFIG_LV_COLOR_DEPTH_16=y
CONFIG_LV_COLOR_DEPTH=16

# --- OS integration -------------------------------------------------------
CONFIG_LV_OS_FREERTOS=y
CONFIG_LV_USE_OS=2

# --- Memory management ----------------------------------------------------
CONFIG_LV_USE_CLIB_MALLOC=y
CONFIG_LV_USE_BUILTIN_STRING=y
CONFIG_LV_USE_CLIB_SPRINTF=y

# --- Widgets used by this example -----------------------------------------
# The bouncing dot is a plain lv_obj — no special widget feature flags needed.
# lv_timer is always available.

# --- Shared object support ------------------------------------------------
CONFIG_ELF_DYNAMIC_LOAD_SHARED_OBJECT=y
