# ESP-IDF build artifacts for the plugin projects
**/build/
**/managed_components/
**/sdkconfig
**/sdkconfig.old
**/dependencies.lock

# Editor / language-server caches
**/.cache/
.vscode/

# OS / tooling junk
.DS_Store
**/__pycache__/
*.pyc

# Internal release-testing checklist (kept local, not shipped in the SDK).
RELEASE_CHECKLIST.md

# The bundled sample plugins under plugins/tuner/ and plugins/standby/ ARE
# tracked. Your own scaffolded projects land alongside them — new_plugin.py drops
# a new project into plugins/<type>/ — and those stay OUT of the SDK repo, so your
# work stays separate and survives a `git pull`. To bundle another sample, add a
# matching `!` line below.
/plugins/tuner/*
/plugins/standby/*
!/plugins/tuner/gauge/
!/plugins/tuner/phase/
!/plugins/standby/bouncer/
!/plugins/standby/hyperdrive/
!/plugins/standby/jamagotchi/
